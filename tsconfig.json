{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,
    "skipLibCheck": true,

    "types": ["node"],

    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"]
    }
  }
}