{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,
    "skipLibCheck": true,

    "types": ["node"],

    "baseUrl": "./src",
    "paths": {
      "@/*": ["*"],
      "@auth/*": ["modules/auth/*"],
      "@config/*": ["config/*"],
      "@utils/*": ["core/utils/*"],
      "@errors/*": ["core/errors/*"],
      "@constants/*": ["core/constants/*"],
      "@middlewares/*": ["middlewares/*"],
      "@modules/*": ["modules/*"],
      "@users/*": ["modules/users/*"],
      "@db/*": ["infrastructure/database/*"],
      "@core/*": ["core/*"],
      "@routes/*": ["routes/*"]
    }
  },
  "include": ["src"]
}