{
  "name": "backend",
  "version": "1.0.0",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js"
  },
  "_moduleAliases": {
    "@": "src",
    "@core": "src/core",
    "@core/*": "src/core/*",
    "@config": "src/config",
    "@config/*": "src/config/*",
    "@utils": "src/core/utils",
    "@utils/*": "src/core/utils/*",
    "@errors": "src/core/errors",
    "@errors/*": "src/core/errors/*",
    "@constants": "src/core/constants",
    "@constants/*": "src/core/constants/*",
    "@middlewares": "src/middlewares",
    "@middlewares/*": "src/middlewares/*",
    "@modules": "src/modules",
    "@modules/*": "src/modules/*",
    "@routes": "src/routes",
    "@routes/*": "src/routes/*",
    "@users": "src/modules/users",
    "@users/*": "src/modules/users/*",
    "@auth": "src/modules/auth",
    "@auth/*": "src/modules/auth/*",
    "@infrastructure": "src/infrastructure",
    "@infrastructure/*": "src/infrastructure/*",
    "@db": "src/infrastructure/database",
    "@db/*": "src/infrastructure/database/*"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "jsonwebtoken": "^9.0.3",
    "module-alias": "^2.3.4",
    "mysql2": "^3.22.2",
    "prisma": "^5.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "nodemon": "^3.1.14"
  },
 "prisma": {
  "seed": "node prisma/seeds/register.seed.js"
}
}
